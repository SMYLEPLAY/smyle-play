# SMYLE PLAY — Variables d'environnement
# Copie ce fichier en .env et remplis tes valeurs réelles.
# Le .env est exclu de Git (voir .gitignore).

# ── Serveur ───────────────────────────────────────────────────────────────────
PORT=8080
DEBUG=true
FLASK_ENV=development
SECRET_KEY=change-this-to-a-long-random-string

# ── Base de données PostgreSQL ────────────────────────────────────────────────
# Laisse vide pour utiliser SQLite en local (smyle_local.db)
# Railway fournit automatiquement DATABASE_URL quand tu ajoutes le plugin PostgreSQL
DATABASE_URL=

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
# Récupère ces valeurs dans : Cloudflare Dashboard → R2 → Manage API Tokens
CLOUD_AUDIO_BASE_URL=https://pub-XXXXXXXXXXXXXXXX.r2.dev
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY=your_r2_access_key_id
R2_SECRET_KEY=your_r2_secret_access_key
R2_BUCKET=smyle-play-audio

# ── CORS (optionnel) ──────────────────────────────────────────────────────────
CORS_ORIGINS=*
